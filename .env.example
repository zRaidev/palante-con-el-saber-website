# EmailJS Configuration
# Get these values from your EmailJS dashboard at https://www.emailjs.com/
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here

# EmailJS Configuration for Reports
# Separate service/template for report submissions
NEXT_PUBLIC_REPORT_EMAILJS_SERVICE_ID=your_report_service_id_here
NEXT_PUBLIC_REPORT_EMAILJS_TEMPLATE_ID=your_report_template_id_here
NEXT_PUBLIC_REPORT_EMAILJS_PUBLIC_KEY=your_report_public_key_here